                </mxCell>
                <mxCell id="121" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;イベントＡのTTL時間内にイベントＣを取得&lt;/font&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;フィルター条件にヒットし、対象のラベルの値がイベントＡと一致しない場合、&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;イベントCは別グループにグルーピングされる&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
